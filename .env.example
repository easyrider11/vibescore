# ─── Required ────────────────────────────────────────────────────

# Supabase PostgreSQL. Use the transaction pooler (:6543) at runtime and
# the direct connection (:5432) for migrations.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres"

# Public app URL (used for candidate invite links, OG metadata, etc.)
NEXT_PUBLIC_APP_URL=https://buildscore.vercel.app

# ─── AI Copilot ─────────────────────────────────────────────────

# Leave AI_MODE=mock for staging / pilot demos. Set to "real" once
# ANTHROPIC_API_KEY is populated.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
AI_MODE=mock

# ─── Distributed rate limiting (optional — falls back to in-memory) ─

# Upstash Redis REST. Create a database at https://console.upstash.com
# and copy the REST URL + token. If either is missing, the app uses a
# per-instance in-memory counter (fine for single-instance pilot,
# inaccurate once Vercel scales out to multiple regions).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Observability (optional) ───────────────────────────────────

# POST-able URL that receives JSON payloads of captured exceptions and
# error-level messages. Works with Sentry envelope endpoints, Axiom
# datasets, Logflare sources, Slack/Discord webhooks. Leave blank to
# rely on stdout-only logging.
OBSERVABILITY_WEBHOOK_URL=
OBSERVABILITY_SERVICE=buildscore

# ─── Email (Resend — required for magic-link auth + candidate invites) ─

RESEND_API_KEY=
RESEND_FROM_EMAIL=Buildscore <noreply@buildscore.dev>

# ─── Collaboration server (optional) ────────────────────────────

# WebSocket URL for the Hocuspocus collab server. If unreachable, live
# candidate sessions degrade gracefully.
NEXT_PUBLIC_WS_URL=ws://localhost:3002

# ─── Billing (optional — leave blank to disable paid plans) ─────

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SessionStatus {
  pending
  active
  completed
  cancelled
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String   @default("")
  role      String   @default("member") // owner, admin, member
  orgId     String?
  createdAt DateTime @default(now())
  sessions  InterviewSession[]
  tokens    SessionToken[]
  org       Organization? @relation(fields: [orgId], references: [id])
}

model Organization {
  id                 String   @id @default(uuid())
  name               String   @default("My Organization")
  defaultAiMode      String   @default("mock") // mock, real
  defaultDurationMin Int      @default(45)
  autoGradeEnabled   Boolean  @default(true)
  allowedAiModes     Json     @default("[\"summary\",\"explain\",\"tests\",\"review\"]")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  members            User[]
}

model SessionToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime @default(dbgenerated("now() + interval '30 days'"))
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MagicLinkToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
}

model Scenario {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  description      String
  background       String
  tasks            Json
  hints            Json
  evaluationPoints Json
  rubric           Json
  aiPolicy         Json
  timeLimitMin     Int?
  createdAt        DateTime @default(now())
  sessions         InterviewSession[]
}

model InterviewSession {
  id              String        @id @default(uuid())
  publicToken     String        @unique
  scenarioId      String
  status          SessionStatus @default(pending)
  candidateName   String        @default("")
  candidateEmail  String        @default("")
  position        String        @default("")
  durationMinutes Int           @default(45)
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime      @default(now())
  createdById     String
  scenario        Scenario      @relation(fields: [scenarioId], references: [id])
  createdBy       User          @relation(fields: [createdById], references: [id])
  events          Event[]
  submissions     Submission[]
  rubricScores    RubricScore[]
  aiGrade         AIGrade?
}

model Event {
  id        String           @id @default(uuid())
  sessionId String
  type      String
  payload   Json
  createdAt DateTime         @default(now())
  session   InterviewSession @relation(fields: [sessionId], references: [id])
}

model Submission {
  id                 String           @id @default(uuid())
  sessionId          String
  snapshot           Json
  diffText           String
  clarificationNotes String?
  createdAt          DateTime         @default(now())
  session            InterviewSession @relation(fields: [sessionId], references: [id])
}

model RubricScore {
  id        String           @id @default(uuid())
  sessionId String
  scores    Json
  comments  String
  decision  String           @default("")
  createdAt DateTime         @default(now())
  session   InterviewSession @relation(fields: [sessionId], references: [id])
}

model AIGrade {
  id            String           @id @default(uuid())
  sessionId     String           @unique
  scores        Json
  decision      String
  summary       String
  strengths     Json
  improvements  Json
  model         String           @default("")
  createdAt     DateTime         @default(now())
  session       InterviewSession @relation(fields: [sessionId], references: [id])
}
